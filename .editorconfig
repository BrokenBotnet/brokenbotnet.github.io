root = true

# Keep text formatting consistent across editors and operating systems.
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Preserve intentional Markdown hard line breaks.
[*.md]
trim_trailing_whitespace = false

# Match the CRLF exceptions in .gitattributes.
[*.{bat,cmd}]
end_of_line = crlf

# Recipes require tabs.
[Makefile]
indent_style = tab
