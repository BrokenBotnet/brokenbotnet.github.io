{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":disableDependencyDashboard", ":prHourlyLimit2"],
  "enabledManagers": ["github-actions", "git-submodules"],
  "git-submodules": {
    "enabled": true
  },
  "labels": ["dependencies"],
  "commitMessagePrefix": "build",
  "rebaseWhen": "behind-base-branch",
  "assignees": ["r3bo0tbx1"],
  "reviewers": ["r3bo0tbx1"],
  "timezone": "Asia/Tokyo",
  "schedule": ["before 3am on monday"],
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "matchManagers": ["git-submodules"],
      "groupName": "risotto theme",
      "labels": ["dependencies", "theme"],
      "automerge": false,
      "schedule": ["at any time"],
      "prPriority": 1
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "labels": ["dependencies", "github-actions"],
      "automerge": false,
      "prPriority": 2
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"],
    "assignees": ["r3bo0tbx1"],
    "schedule": ["at any time"]
  },
  "osvVulnerabilityAlerts": true
}
